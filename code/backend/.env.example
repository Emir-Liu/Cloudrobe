# 应用配置
APP_NAME=云衣橱
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cloudrobe
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 微信配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 腾讯云COS配置
TENCENT_COS_SECRET_ID=your-cos-secret-id
TENCENT_COS_SECRET_KEY=your-cos-secret-key
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=cloudrobe-bucket

# 短信配置
SMS_ACCESS_KEY_ID=your-sms-access-key-id
SMS_ACCESS_KEY_SECRET=your-sms-access-key-secret
SMS_APP_ID=your-sms-app-id
SMS_TEMPLATE_ID=123456

# 文件上传配置
UPLOAD_MAX_SIZE=10485760
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS配置
CORS_ORIGINS=http://localhost:3000,https://localhost:3000
CORS_ALLOW_CREDENTIALS=True
